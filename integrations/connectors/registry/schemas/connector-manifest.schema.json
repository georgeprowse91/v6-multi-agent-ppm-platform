{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Connector Manifest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "protocol": {
      "type": "string",
      "enum": [
        "mcp"
      ]
    },
    "protocol_version": {
      "type": "string"
    },
    "tool_map": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      ]
    },
    "resource_map": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "prompt_map": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "mcp_server_id": {
      "type": "string"
    },
    "mcp_server_url": {
      "type": "string"
    },
    "mcp_scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mcp_tool_map": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "oauth2",
            "api_key",
            "basic",
            "token"
          ]
        },
        "token_url": {
          "type": "string"
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "type",
        "fields"
      ]
    },
    "sync": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "full",
              "incremental"
            ]
          }
        },
        "default_schedule": {
          "type": "string"
        },
        "supports_webhooks": {
          "type": "boolean"
        },
        "rate_limit_per_minute": {
          "type": "integer",
          "minimum": 1
        },
        "workloads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "modes",
        "default_schedule",
        "supports_webhooks"
      ]
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "mapping_file": {
            "type": "string"
          }
        },
        "required": [
          "source",
          "target",
          "mapping_file"
        ]
      },
      "minItems": 1
    },
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server_id": {
          "type": "string"
        },
        "server_url": {
          "type": "string"
        },
        "protocol_version": {
          "type": "string"
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tool_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "resource_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "prompt_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "maturity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "tier": {
          "type": "string",
          "enum": [
            "candidate",
            "core",
            "strategic"
          ]
        },
        "business_priority": {
          "type": "integer",
          "minimum": 1
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read": {
              "type": "boolean"
            },
            "write": {
              "type": "boolean"
            },
            "webhook": {
              "type": "boolean"
            },
            "declarative_mapping": {
              "type": "boolean"
            },
            "idempotent_write": {
              "type": "boolean"
            },
            "conflict_handling": {
              "type": "boolean"
            }
          },
          "required": [
            "read",
            "write",
            "webhook",
            "declarative_mapping",
            "idempotent_write",
            "conflict_handling"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "level",
        "tier",
        "business_priority",
        "capabilities"
      ]
    }
  },
  "required": [
    "id",
    "version",
    "name",
    "description",
    "owner",
    "category",
    "auth",
    "sync",
    "mappings",
    "maturity"
  ]
}
