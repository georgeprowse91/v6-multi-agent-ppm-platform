WORKDAY_CLIENT_ID=your-client-id
WORKDAY_CLIENT_SECRET=your-client-secret
WORKDAY_REFRESH_TOKEN=your-refresh-token
WORKDAY_TOKEN_URL=https://wd2-impl-services1.workday.com/ccx/oauth2/token
WORKDAY_PROJECTS_ENDPOINT=/projects

# -----------------------------------------------------------------------------
# CRM
# -----------------------------------------------------------------------------
# Salesforce
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
SALESFORCE_CLIENT_ID=your-client-id
SALESFORCE_CLIENT_SECRET=your-client-secret
SALESFORCE_REFRESH_TOKEN=your-refresh-token
SALESFORCE_PROJECTS_ENDPOINT=/services/data/v57.0/sobjects/Project__c

# SAP SuccessFactors
SF_API_SERVER=https://api.successfactors.com
