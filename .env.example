# Multi-Agent PPM Platform - Environment Configuration
# Copy this file to .env and fill in your values

# Azure OpenAI Configuration
# Core Azure OpenAI connection settings used by the API gateway and LLM clients.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# Database Configuration
# Primary database connection string and pool tuning for the API gateway.
DATABASE_URL=postgresql://ppm:ppm_password@localhost:5432/ppm
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration
# Cache/broker endpoint used for rate limiting and background coordination.
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Azure Cosmos DB (optional, for production)
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key
COSMOS_DATABASE=ppm

# Azure Service Bus (for event-driven architecture)
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=...
SERVICE_BUS_QUEUE_NAME=ppm-events

# Azure Key Vault
KEY_VAULT_URL=https://your-vault.vault.azure.net/

# Application Configuration
APP_NAME=Multi-Agent PPM Platform
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# Agent Configuration
MAX_AGENT_CONCURRENCY=5
AGENT_TIMEOUT_SECONDS=30
CACHE_TTL_SECONDS=900

# External Search (Scope Research)
SEARCH_API_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
SEARCH_API_KEY=your-search-api-key
SEARCH_API_MIN_INTERVAL=1.0
SEARCH_RESULT_LIMIT=5

# =============================================================================
# CONNECTOR CONFIGURATION
# =============================================================================
# Connector config file encryption (optional, generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CONNECTOR_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Jira Connector (PM Tools - Available)
# Required for Jira integration
# -----------------------------------------------------------------------------
JIRA_INSTANCE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token

# -----------------------------------------------------------------------------
# PPM Tools
# -----------------------------------------------------------------------------
# Planview
PLANVIEW_INSTANCE_URL=https://your-instance.planview.com
PLANVIEW_CLIENT_ID=your-client-id
PLANVIEW_CLIENT_SECRET=your-client-secret
PLANVIEW_REFRESH_TOKEN=your-refresh-token

# Clarity PPM
CLARITY_INSTANCE_URL=https://your-instance.ca.com/niku/nu
CLARITY_CLIENT_ID=your-client-id
CLARITY_CLIENT_SECRET=your-client-secret
CLARITY_REFRESH_TOKEN=your-refresh-token

# Microsoft Project Server
MS_PROJECT_SITE_URL=https://your-instance.sharepoint.com/sites/pwa
MS_PROJECT_TENANT_ID=your-azure-tenant-id
MS_PROJECT_CLIENT_ID=your-client-id
MS_PROJECT_CLIENT_SECRET=your-client-secret
MS_PROJECT_REFRESH_TOKEN=your-refresh-token

# -----------------------------------------------------------------------------
# PM Tools
# -----------------------------------------------------------------------------
# Azure DevOps
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-org
AZURE_DEVOPS_PAT=your-personal-access-token

# Monday.com
MONDAY_API_TOKEN=your-api-token

# Asana
ASANA_ACCESS_TOKEN=your-access-token

# -----------------------------------------------------------------------------
# Document Management
# -----------------------------------------------------------------------------
# SharePoint
SHAREPOINT_SITE_URL=https://your-instance.sharepoint.com/sites/your-site
SHAREPOINT_CLIENT_ID=your-client-id
SHAREPOINT_CLIENT_SECRET=your-client-secret
SHAREPOINT_REFRESH_TOKEN=your-refresh-token

# Confluence
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=your-api-token

# Google Drive
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# -----------------------------------------------------------------------------
# ERP Systems
# -----------------------------------------------------------------------------
# SAP
SAP_URL=https://your-sap-instance.com
SAP_USERNAME=your-username
SAP_PASSWORD=your-password
SAP_CLIENT=100
SAP_PROJECTS_ENDPOINT=/api/projects

# Oracle ERP Cloud
ORACLE_URL=https://your-instance.oraclecloud.com
ORACLE_CLIENT_ID=your-client-id
ORACLE_CLIENT_SECRET=your-client-secret
ORACLE_REFRESH_TOKEN=your-refresh-token

# NetSuite
NETSUITE_ACCOUNT_ID=your-account-id
NETSUITE_REST_URL=https://your-account.suitetalk.api.netsuite.com
NETSUITE_CONSUMER_KEY=your-consumer-key
NETSUITE_CONSUMER_SECRET=your-consumer-secret
