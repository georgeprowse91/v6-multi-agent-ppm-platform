# ============================================================================
# DEV-ONLY LOCAL DEFAULTS
# ============================================================================
# WARNING:
# - This file is for local development only.
# - Never reuse these values in CI, staging, or production.
# - CI/prod must source secrets from a secure secret manager.
# ============================================================================

# Core local database settings (dev-only)
POSTGRES_DB=ppm_local
POSTGRES_USER=ppm_local
POSTGRES_PASSWORD=replace_me_local_password

# API service local wiring (dev-only)
DATABASE_URL=postgresql://ppm_local:replace_me_local_password@db:5432/ppm_local
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=INFO
ENVIRONMENT=development
ORCHESTRATION_STATE_BACKEND=db

# Local auth dev mode (dev-only)
AUTH_DEV_MODE=true
AUTH_DEV_ROLES=PMO_ADMIN
AUTH_DEV_TENANT_ID=dev-tenant-local

# LLM local defaults
LLM_PROVIDER=mock
LLM_MOCK_RESPONSE_PATH=/app/examples/demo-scenarios/quickstart-llm-response.json

# Optional Azure OpenAI values for local development
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Web service local wiring
API_GATEWAY_URL=http://api:8000
IDENTITY_ACCESS_URL=http://identity-access:8080
WORKFLOW_ENGINE_URL=http://workflow-engine:8080

# Optional external research configuration
SEARCH_API_ENDPOINT=
SEARCH_API_KEY=
SEARCH_API_MIN_INTERVAL=
SEARCH_RESULT_LIMIT=
