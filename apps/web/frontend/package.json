{
  "name": "@ppm/web-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "css-modules:types": "node scripts/generate-css-module-types.mjs",
    "pretypecheck": "npm run css-modules:types",
    "prebuild": "npm run css-modules:types",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 10",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "lint:tokens": "node scripts/check-design-tokens.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:api-boundary": "node scripts/check-raw-json-casts.mjs",
    "css-modules:check": "npm run css-modules:types && tsc -p tsconfig.css-modules.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook --storybook-build-dir storybook-static --failOnConsole"
  },
  "dependencies": {
    "@ppm/canvas-engine": "workspace:*",
    "lucide-react": "^0.469.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-intl": "^6.6.4",
    "reactflow": "^11.11.4",
    "react-router-dom": "^6.22.0",
    "shepherd.js": "^11.2.0",
    "zustand": "^4.5.0",
    "@ppm/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/node": "^25.0.10",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "axe-core": "^4.9.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.0.0",
    "typescript": "catalog:",
    "vite": "^5.2.0",
    "vitest": "^1.3.0",
    "@storybook/addon-a11y": "^8.5.2",
    "@storybook/addon-essentials": "^8.5.2",
    "@storybook/addon-interactions": "^8.5.2",
    "@storybook/react-vite": "^8.5.2",
    "@storybook/test": "^8.5.2",
    "@storybook/test-runner": "^0.19.1",
    "storybook": "^8.5.2"
  }
}
