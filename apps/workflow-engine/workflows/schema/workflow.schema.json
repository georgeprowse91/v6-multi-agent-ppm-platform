{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowDefinition",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "steps"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "pattern": "^ppm.workflows/v1$"
    },
    "kind": {
      "type": "string",
      "const": "Workflow"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "version",
        "owner"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "next"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "task",
              "decision",
              "notification"
            ]
          },
          "next": {
            "type": [
              "string",
              "null"
            ]
          },
          "config": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}