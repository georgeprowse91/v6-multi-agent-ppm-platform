      "assistant": { "icon": "Sparkles", "color": "accent", "size": "md" },
      "message": { "icon": "MessageSquare", "color": "secondary", "size": "md" },
      "attachment": { "icon": "Paperclip", "color": "secondary", "size": "md" },
      "voiceInput": { "icon": "Mic", "color": "secondary", "size": "md" },
      "notifications": { "icon": "Bell", "color": "secondary", "size": "md" },
      "send": { "icon": "Send", "color": "secondary", "size": "md" }
    },
    "domain": {
