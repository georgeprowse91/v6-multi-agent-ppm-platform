      "delivery": { "icon": "Rocket", "color": "secondary", "size": "md" },
      "operations": { "icon": "Wrench", "color": "secondary", "size": "md" },
      "platform": { "icon": "Server", "color": "secondary", "size": "md" },
      "governance": { "icon": "Shield", "color": "secondary", "size": "md" },
      "program": { "icon": "Layers", "color": "secondary", "size": "md" },
      "project": { "icon": "Folder", "color": "secondary", "size": "md" },
      "budget": { "icon": "DollarSign", "color": "secondary", "size": "md" }
    },
    "artifact": {
      "document": { "icon": "FileText", "color": "secondary", "size": "md" },
      "tree": { "icon": "GitBranch", "color": "secondary", "size": "md" },
      "timeline": { "icon": "Calendar", "color": "secondary", "size": "md" },
      "spreadsheet": { "icon": "Table", "color": "secondary", "size": "md" },
      "dashboard": { "icon": "LayoutDashboard", "color": "secondary", "size": "md" },
      "folder": { "icon": "Folder", "color": "secondary", "size": "md" },
      "sheet": { "icon": "Table", "color": "secondary", "size": "md" },
      "milestone": { "icon": "Flag", "color": "secondary", "size": "md" },
      "note": { "icon": "StickyNote", "color": "secondary", "size": "md" },
      "package": { "icon": "Package", "color": "secondary", "size": "md" }
    },
    "connectors": {
      "jira": { "icon": "ClipboardList", "color": "secondary", "size": "md" },
      "azure": { "icon": "Server", "color": "secondary", "size": "md" },
      "slack": { "icon": "MessageSquare", "color": "secondary", "size": "md" },
      "teams": { "icon": "User", "color": "secondary", "size": "md" },
      "sharepoint": { "icon": "Folder", "color": "secondary", "size": "md" },
      "cpuChip": { "icon": "Cpu", "color": "secondary", "size": "md" },
      "default": { "icon": "Link2", "color": "secondary", "size": "md" }
