modules = ["python-3.11", "nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "libyaml", "openssl", "pkg-config", "pnpm", "postgresql", "rustc"]

[userenv]

[userenv.shared]
ENVIRONMENT = "development"
AUTH_DEV_MODE = "true"
AUTH_DEV_ROLES = "PMO_ADMIN"
AUTH_DEV_TENANT_ID = "dev-tenant-local"
LLM_PROVIDER = "mock"
DEMO_MODE = "true"
LOG_LEVEL = "INFO"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Web Backend"

[[workflows.workflow]]
name = "Web Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python start_web.py & sleep 3 && cd /home/runner/workspace/apps/web/frontend && npx vite --port 5000 --host 0.0.0.0"
waitForPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd /home/runner/workspace && python start_web.py"]
build = ["bash", "-c", "cd /home/runner/workspace/apps/web/frontend && npx vite build"]
