{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Connector Mapping",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "source": {"type": "string", "minLength": 1},
    "target": {"type": "string", "minLength": 1},
    "schema": {"type": "string"},
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "source": {"type": "string"},
          "target": {"type": "string"},
          "transform": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "type": {"type": "string"}
            },
            "required": ["type"]
          }
        },
        "required": ["source", "target"]
      }
    },
    "transformations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "field": {"type": "string"},
          "type": {"type": "string"}
        },
        "required": ["field", "type"]
      }
    }
  },
  "required": ["source", "target", "fields"]
}
