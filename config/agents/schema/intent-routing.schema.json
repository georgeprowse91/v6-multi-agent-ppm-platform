{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Intent Routing Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "intents"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "default_min_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "fallback_intent": {
      "type": "string",
      "minLength": 1
    },
    "intents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "min_confidence", "routes"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "min_confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "routes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["agent_id"],
              "properties": {
                "agent_id": {
                  "type": "string",
                  "minLength": 1
                },
                "action": {
                  "type": "string"
                },
                "dependencies": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
