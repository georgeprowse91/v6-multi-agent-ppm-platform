{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Demand Intake Request",
  "type": "object",
  "required": [
    "title",
    "description",
    "business_objective"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "business_objective": {
      "type": "string",
      "minLength": 1
    },
    "requester": {
      "type": "string"
    },
    "business_unit": {
      "type": "string"
    },
    "urgency": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ]
    },
    "source": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "x-schema-metadata": {
    "name": "demand",
    "version": "1.0.0",
    "compatibility_mode": "full"
  }
}
