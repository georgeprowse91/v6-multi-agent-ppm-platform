{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Resource",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "on_leave",
        "allocated"
      ]
    },
    "program_id": {
      "type": "string"
    },
    "cost_rate": {
      "type": "number"
    },
    "skills": {
      "type": "array",
      "items": {"type": "string"}
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "capacity_hours_per_week": {
      "type": "number"
    },
    "allocation_pct": {
      "type": "number"
    },
    "availability_pct": {
      "type": "number"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    }
  },
  "required": [
    "id",
    "tenant_id",
    "name",
    "role",
    "status",
    "created_at"
  ],
  "x-schema-metadata": {
    "name": "resource",
    "version": "1.0.0",
    "compatibility_mode": "full"
  }
}
