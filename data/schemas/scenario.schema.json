{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scenario",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "evaluated",
        "archived"
      ]
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_name": {
          "type": "string"
        },
        "entity_id": {
          "type": "string"
        },
        "schema_version": {
          "type": "integer"
        },
        "baseline_id": {
          "type": "string"
        },
        "reference_type": {
          "type": "string",
          "enum": [
            "entity",
            "baseline",
            "snapshot"
          ]
        }
      },
      "required": [
        "schema_name",
        "entity_id"
      ]
    },
    "deltas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "delta_id": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "payload": {
            "type": "object",
            "additionalProperties": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "domain",
          "payload"
        ]
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "tenant_id",
    "name",
    "baseline",
    "deltas",
    "created_at"
  ],
  "x-schema-metadata": {
    "name": "scenario",
    "version": "1.0.0",
    "compatibility_mode": "full"
  }
}
