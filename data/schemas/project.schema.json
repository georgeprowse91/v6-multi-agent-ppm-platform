{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "program_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "initiated",
        "planning",
        "execution",
        "monitoring",
        "closed"
      ]
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "benefits_realisation_plan": {
      "type": "string"
    },
    "regulatory_category": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "tenant_id",
    "program_id",
    "name",
    "status",
    "start_date",
    "owner",
    "classification",
    "created_at"
  ],
  "x-schema-metadata": {
    "name": "project",
    "version": "1.1.0",
    "compatibility_mode": "full"
  }
}
