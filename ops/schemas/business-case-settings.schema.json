{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Business Case Settings Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "discount_rate",
    "inflation_rate",
    "currency_rates",
    "simulation_iterations",
    "sensitivity_variations"
  ],
  "properties": {
    "discount_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "inflation_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "currency_rates": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "number",
        "exclusiveMinimum": 0
      }
    },
    "simulation_iterations": {
      "type": "integer",
      "minimum": 1
    },
    "sensitivity_variations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "number"
      }
    }
  }
}
