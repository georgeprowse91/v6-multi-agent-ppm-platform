{
  "title": "PPM Platform Overview",
  "panels": [
    {
      "type": "timeseries",
      "title": "API Gateway Latency (p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"api-gateway\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Gateway Throughput",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"api-gateway\"}[5m]))",
          "legendFormat": "requests/sec"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Gateway Error Rate",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"api-gateway\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{service=\"api-gateway\"}[5m]))",
          "legendFormat": "error_rate"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Workflow Success Rate",
      "targets": [
        {
          "expr": "sum(rate(workflow_completed_total{status=\"success\"}[5m])) / sum(rate(workflow_executions_total[5m]))",
          "legendFormat": "success_rate"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connector Sync Duration (p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(connector_sync_execution_duration_seconds_bucket[15m])) by (le, connector_id))",
          "legendFormat": "{{connector_id}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connector Sync Throughput",
      "targets": [
        {
          "expr": "sum(rate(connector_sync_executions_total[15m])) by (connector_id)",
          "legendFormat": "{{connector_id}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Audit Log Ingest",
      "targets": [
        {
          "expr": "sum(rate(audit_events_ingested_total[5m]))",
          "legendFormat": "ingest_rate"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Agent Requests by Outcome",
      "targets": [
        {
          "expr": "sum(rate(agent_requests_total[5m])) by (agent_name, outcome)",
          "legendFormat": "{{agent_name}} {{outcome}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Agent Request Latency (p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_request_latency_seconds_bucket[5m])) by (le, agent_name))",
          "legendFormat": "{{agent_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "MCP Call Volume by System",
      "targets": [
        {
          "expr": "sum(rate(mcp_client_requests_total[5m])) by (system)",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "MCP Error Rate by System",
      "targets": [
        {
          "expr": "sum(rate(mcp_client_requests_total{outcome=\"error\"}[5m])) by (system) / sum(rate(mcp_client_requests_total[5m])) by (system)",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "MCP Fallback Rate by System",
      "targets": [
        {
          "expr": "sum(rate(mcp_client_fallback_total[5m])) by (system) / sum(rate(mcp_client_requests_total[5m])) by (system)",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "MCP Client Latency (p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(mcp_client_latency_seconds_bucket[5m])) by (le, system, tool_name))",
          "legendFormat": "{{system}} {{tool_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "MCP Client Error Rate",
      "targets": [
        {
          "expr": "sum(rate(mcp_client_requests_total{outcome=\"error\"}[5m])) / sum(rate(mcp_client_requests_total[5m]))",
          "legendFormat": "error_rate"
        }
      ]
    },
    {
      "id": 1,
      "title": "Dependency Circuit Breaker State Transitions",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (dependency,to_state) (rate(dependency_circuit_breaker_state_transitions_total[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 40
      }
    },
    {
      "id": 2,
      "title": "Dependency Open Circuit Denials",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (dependency) (rate(dependency_circuit_breaker_open_denials_total[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 40
      }
    }
  ]
}
