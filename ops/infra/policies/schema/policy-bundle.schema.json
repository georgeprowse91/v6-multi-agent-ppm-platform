{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PolicyBundle",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "policies"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "pattern": "^ppm\\.policies/v1$"
    },
    "kind": {
      "type": "string",
      "const": "PolicyBundle"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "version",
        "owner",
        "scope"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "severity",
          "enforcement",
          "rules"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "enforcement": {
            "type": "string",
            "enum": [
              "advisory",
              "blocking"
            ]
          },
          "rules": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "field",
                "operator",
                "value"
              ],
              "properties": {
                "field": {
                  "type": "string"
                },
                "operator": {
                  "type": "string",
                  "enum": [
                    "equals",
                    "contains",
                    "not_contains",
                    "gte",
                    "lte"
                  ]
                },
                "value": {}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}