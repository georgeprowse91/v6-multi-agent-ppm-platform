# Kubernetes Secrets Template
# Copy this file to secrets.yaml and fill in your values
# DO NOT commit secrets.yaml to version control

apiVersion: v1
kind: Secret
metadata:
  name: ppm-secrets
type: Opaque
stringData:
  database-url: "postgresql://user:password@host:5432/database"
  redis-url: "redis://host:6379/0"
  azure-openai-endpoint: "https://your-resource.openai.azure.com/"
  azure-openai-api-key: "your-api-key"
  azure-openai-deployment: "gpt-4"
  service-bus-connection-string: "Endpoint=sb://..."
  cosmos-endpoint: "https://your-account.documents.azure.com:443/"
  cosmos-key: "your-cosmos-key"
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: ppm-config
data:
  APP_NAME: "Multi-Agent PPM Platform"
  APP_VERSION: "0.1.0"
  ENVIRONMENT: "production"
  LOG_LEVEL: "INFO"
  MAX_AGENT_CONCURRENCY: "5"
  AGENT_TIMEOUT_SECONDS: "30"
  AGENT_CALL_TIMEOUT: "30.0"
  CACHE_TTL_SECONDS: "900"
