{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnalyticsJobManifest",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "schedule",
    "inputs",
    "outputs",
    "steps"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "pattern": "^ppm.jobs/v1$"
    },
    "kind": {
      "type": "string",
      "const": "AnalyticsJob"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "owner",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "schedule": {
      "type": "object",
      "required": [
        "cron",
        "timezone"
      ],
      "properties": {
        "cron": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "source",
          "format"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "format": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "destination",
          "format"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "destination": {
            "type": "string"
          },
          "format": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "config"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "config": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}