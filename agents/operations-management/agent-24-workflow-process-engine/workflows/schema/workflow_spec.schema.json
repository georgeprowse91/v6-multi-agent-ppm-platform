{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowSpec",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "steps"],
  "properties": {
    "apiVersion": { "type": "string", "const": "ppm.workflow/v1" },
    "kind": { "type": "string", "const": "Workflow" },
    "metadata": {
      "type": "object",
      "required": ["name", "version", "owner"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "owner": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["task", "human", "automated", "approval", "notification", "script", "decision", "parallel", "loop"]
          },
          "task_type": { "type": "string" },
          "initial": { "type": "boolean" },
          "next": { "type": ["string", "array", "null"], "items": { "type": "string" } },
          "default_next": { "type": ["string", "null"] },
          "exit": { "type": ["string", "null"] },
          "branches": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["next"],
              "properties": {
                "name": { "type": "string" },
                "condition": {
                  "type": "object",
                  "required": ["field", "operator"],
                  "properties": {
                    "field": { "type": "string" },
                    "operator": {
                      "type": "string",
                      "enum": ["equals", "not_equals", "greater_than", "less_than", "contains", "exists"]
                    },
                    "value": {}
                  },
                  "additionalProperties": false
                },
                "next": { "type": ["string", "null"] }
              },
              "additionalProperties": false
            }
          },
          "retry": {
            "type": "object",
            "properties": {
              "max_attempts": { "type": "integer", "minimum": 1 },
              "backoff_seconds": { "type": "integer", "minimum": 0 },
              "delay_seconds": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          },
          "callable": { "type": "string" },
          "script": { "type": "string" },
          "config": { "type": "object" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
